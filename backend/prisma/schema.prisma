generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User account status
enum UserAccountStatus {
  ACTIVE
  INACTIVE
  SUSPEND
}

// User role for authorization and feature access
enum UserRole {
  ADMIN
  USER
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  password     String
  firstName    String?
  lastName     String?
  phone        String?
  profileImage String?
  role         UserRole          @default(USER)
  status       UserAccountStatus @default(ACTIVE)
  lastLogin    DateTime?
  verified     Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
